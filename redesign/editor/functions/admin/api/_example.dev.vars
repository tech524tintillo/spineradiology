# Example secrets for LIVE Cloudflare Pages Functions.
# Copy to the Pages project's Environment Variables (NOT committed).
# In local `wrangler pages dev` these can live in a .dev.vars file
# at the Pages project root (which must be gitignored).
#
# DO NOT put a real token in the repo. The token referenced in the
# spec as "exposed" must be ROTATED before any of this goes live.

GITHUB_TOKEN=github_pat_xxx_fine_grained_single_repo_contents_rw_pr_rw
GITHUB_OWNER=your-github-owner
GITHUB_REPO=spineradiology
BASE_BRANCH=redesign-templates
DOCS_PREFIX=docs/
